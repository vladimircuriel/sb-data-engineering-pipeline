# Airflow
FERNET_KEY=your_fernet_key_here
AIRFLOW_UID=50000

# Airflow metadata database (internal PostgreSQL)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Landing zone database (PostgreSQL)
LANDING_POSTGRES_USER=landing
LANDING_POSTGRES_PASSWORD=landing
LANDING_POSTGRES_DB=landing
LANDING_DB_CONN=postgresql+psycopg2://landing:landing@postgres_landing/landing

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password
CLICKHOUSE_DB=default

# Airbyte — HTTP connection from Airflow to Airbyte API
# Format: http://<user>:<password>@<host>:<port>
AIRFLOW_CONN_AIRBYTE_DEFAULT=http://airbyte:password@localhost:8000

# Airbyte connection ID for the landing -> ClickHouse sync
# Find this in the Airbyte UI under Connections
AIRFLOW_VAR_AIRBYTE_LANDING_TO_CLICKHOUSE_CONNECTION_ID=your_airbyte_connection_uuid

# Docker
HOST_PROJ_DIR=/absolute/path/to/sb-data-engineering-pipeline
COMPOSE_PROJECT_NAME=sb-pipeline
